echo "Running pre-push checks..."

echo "Checking ESLint..."
if ! npm run lint --silent 2>&1; then
  echo ""
  echo "❌ ERROR: Lint issues found!"
  exit 1
fi

echo "Checking TypeScript..."
if ! npm run type-check --silent 2>&1; then
  echo ""
  echo "❌ ERROR: Type-check failed!"
  exit 1
fi

echo "Checking Prettier formatting..."
if ! npm run format:check --silent 2>&1; then
  echo ""
  echo "❌ ERROR: Prettier formatting issues found!"
  echo "Run 'npm run format' to fix them, then commit/amend and push again."
  exit 1
fi

echo "✅ Pre-push checks passed!"
